#include<stdio.h>
#include<stdlib.h>
#include<locale.h>

void menu ()
{
    printf("\t\t\tMENU DE EXERCÍCIOS\n");
    printf("Digite 0 para finalizar\n");
    printf("Digite 1: Tabuada de 1 até 10 de um número N\n");
    printf("Digite 2: Fatorial de um número N\n");
    printf("Digite 3: Inverso de um número N\n");
    printf("Digite 4: Descubra se um número N é um número primo\n");
    printf("Informe a opção: ");
}

int main()
{
    setlocale(LC_ALL, "Portuguese");
    int opcao, valor=1, num2, num3, num4, num5, num6, num7, cont, ePrimo, resultadoF=0;
    float num1, resultado;

    do
    {
        menu ();
        scanf("%d", &opcao);

        if(opcao >= 0 && opcao <= 4)
        {
            switch (opcao)
            {
                case 1:
                    printf("\n\nDigite um número para saber sua tabuada de 1 até 10: ");
                    scanf("%f", &num1);

                    for (int i = 0; i < 10; ++i)
                    {
                        resultado = num1 * valor;
                        printf("A multiplicação de %.2f por %d é: %.2f\n", num1, valor, resultado);
                        valor = valor + 1;
                    }
                    printf("\n\n\n");
                    break;
                
                case 2:
                    printf("\n\nDigite um número inteiro para saber seu fatorial: \n");
                    scanf("%d", &num2);
                    
                    num3=num2-1;
                    num4=num2;
                    
                    do
                    {
                        resultadoF = num2*num3;
                        num2=resultadoF;
                        
                        num3-=1;
                    } while (num3>0);
                    printf("O fatorial do número %d é: %d", num4, resultadoF);
                    printf("\n\n\n");
                    break;
                    
                case 3:
                    printf("\n\nDigite um número inteiro para saber seu inverso: \n");
                    scanf("%d", &num5);
                    
                    num6=0;
                    
                    while(num5>0)
                    {
                        num6=num5%10;
                        num5/=10;
                        printf("%d", num6);
                    }
                    printf("\n\n\n");
                    break;
                    
                case 4:
                    printf("\n\nDigite um número inteiro positivo para saber se ele é primo: ");
                    scanf("%d", &num7);
                    
                    ePrimo=1;
                    
                    if(num7>1)
                    {
                        for(cont=2; cont<num7; cont++)
                        {
                            if(num7%cont==0)
                            {
                                ePrimo=0;
                                break;
                            }
                        }
                        if(ePrimo==1)
                        {
                            printf("O número %d é primo", num7);
                        } else {
                            printf("O número %d não é primo", num7);
                        }
                    } else {
                        printf("0, 1 e números negativos não fazem parte dos números primos!!!");
                    }
                    printf("\n\n\n");
                    break;
            }
        }
        else
        {
            printf("OPÇÃO INVÁLIDA!!\n");
        }
    } while (opcao != 0);

    return 0;
}
